APP_NAME="Trace FC"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Préfixe de la route admin (doit correspondre à VITE_ADMIN_PREFIX côté frontend)
ADMIN_PREFIX=gestion-trace-admin

LOG_CHANNEL=stack

# ─── BASE DE DONNÉES MySQL ────────────────────────────────────
# Créer la base : CREATE DATABASE trace_fc CHARACTER SET utf8mb4;
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=trace_fc
DB_USERNAME=root
DB_PASSWORD=

# ─── API Football ─────────────────────────────────────────────
# Gratuite sur : https://www.football-data.org/client/register
FOOTBALL_API_KEY=

# ─────────────────────────────────────────────────────────────
# PAYTECH — Paiement principal (Wave + Orange Money via PayTech)
# Obtenir sur : https://paytech.sn/
# Étapes : S'inscrire > Tableau de bord > API Keys
# PayTech regroupe Wave, Orange Money, Free Money en un seul accès
# ─────────────────────────────────────────────────────────────
PAYTECH_API_KEY=PAYTECH_API_KEY_ICI
PAYTECH_API_SECRET=PAYTECH_API_SECRET_ICI
PAYTECH_BASE_URL=https://paytech.sn/api

# ─────────────────────────────────────────────────────────────
# WAVE API — Accès direct optionnel (si hors PayTech)
# Obtenir sur : https://wave.com/business
# Étapes : Créer compte entreprise > Intégrations > Générer clé API
# ─────────────────────────────────────────────────────────────
WAVE_API_KEY=WAVE_KEY_ICI
WAVE_WEBHOOK_SECRET=WAVE_WEBHOOK_ICI
WAVE_BASE_URL=https://api.wave.com/v1

# ─────────────────────────────────────────────────────────────
# ORANGE MONEY API — Accès direct optionnel (si hors PayTech)
# Obtenir sur : https://developer.orange.com
# Étapes : S'inscrire > Créer App > Activer "Orange Money Payments SN"
# ─────────────────────────────────────────────────────────────
ORANGE_MONEY_API_KEY=OM_CLIENT_ID_ICI
ORANGE_MONEY_MERCHANT_KEY=OM_CLIENT_SECRET_ICI
ORANGE_MONEY_BASE_URL=https://api.orange.com/orange-money-webpay/sn/v1
ORANGE_MONEY_TOKEN_URL=https://api.orange.com/oauth/v3/token

SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:3000,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173

SESSION_DRIVER=database
SESSION_LIFETIME=120
