# Configuration frontend — Copier en .env puis adapter
# ─────────────────────────────────────────────────────
# URL de l'API Laravel backend
VITE_API_URL=/api

# Préfixe du chemin admin (doit correspondre à ADMIN_PREFIX dans backend/.env)
# Accès admin : http://localhost:5173/trace-admin
VITE_ADMIN_PREFIX=trace-admin
